{
  "name": "healthyai-backend",
  "version": "1.0.0",
  "description": "Backend API for HealthyAI",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:dev": "nodemon server.js",
