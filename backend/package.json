    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.2",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.1",
    "openai": "^4.57.0",
    "pdfkit": "^0.18.0",
    "pdfmake": "^0.2.23",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
